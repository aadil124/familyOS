generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DocumentProcessingStatus {
  PENDING
  OCR_PROCESSING
  AI_PROCESSING
  SUCCESS
  FAILED
}

enum OCRStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DocumentReviewStatus {
  UNREVIEWED
  PENDING_REVIEW
  REVIEWED
  USER_VERIFIED
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id              String         @id @default(uuid())
  fullName        String
  email           String         @unique
  passwordHash    String
  status          String
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  families            Family[]
  refreshTokens       RefreshToken[]
  readinessAssessments ReadinessAssessment[]
  aiConversations     AIConversation[]

  @@map("users")
}

model Family {
  id          String    @id @default(uuid())
  ownerUserId String
  name        String
  status      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  owner                User                  @relation(fields: [ownerUserId], references: [id])
  members              FamilyMember[]
  documents            Document[]
  readinessAssessments ReadinessAssessment[]
  aiConversations      AIConversation[]

  @@map("families")
}

model FamilyMember {
  id           String    @id @default(uuid())
  familyId     String
  fullName     String
  relationship String?
  dateOfBirth  DateTime?
  primaryEmail String?
  primaryPhone String?
  status       String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  family               Family                @relation(fields: [familyId], references: [id])
  documents            Document[]
  readinessAssessments ReadinessAssessment[]

  @@map("family_members")
}

model DocumentCategory {
  id            String    @id @default(uuid())
  name          String
  description   String?
  normalizedKey String    @unique
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  documents     Document[]

  @@map("document_categories")
}

model Document {
  id                  String                   @id @default(uuid())
  familyId            String
  familyMemberId      String?
  categoryId          String?
  originalFileName    String
  displayName         String
  fileType            String
  fileSize            Int?
  storageProvider     String
  storageAssetId      String
  storageUrlReference String?
  uploadStatus        String
  processingStatus    DocumentProcessingStatus @default(PENDING)
  reviewStatus        DocumentReviewStatus     @default(UNREVIEWED)
  issueStatus         String?
  issuedAt            DateTime?
  expiresAt           DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  deletedAt           DateTime?

  family              Family                   @relation(fields: [familyId], references: [id])
  familyMember        FamilyMember?            @relation(fields: [familyMemberId], references: [id])
  category            DocumentCategory?        @relation(fields: [categoryId], references: [id])
  
  ocrResult           OCRResult?
  documentAnalysis    DocumentAnalysis?

  @@index([familyId])
  @@index([categoryId])
  @@index([familyMemberId])
  @@map("documents")
}

model OCRResult {
  id              String    @id @default(uuid())
  documentId      String    @unique
  provider        String
  providerVersion String
  status          OCRStatus @default(PENDING)
  extractedText   String?   @db.Text
  textReference   String?
  languageHints   String?
  confidenceScore Float?
  failureReason   String?
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  document        Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("ocr_results")
}

model DocumentAnalysis {
  id                   String         @id @default(uuid())
  documentId           String         @unique
  provider             String
  providerVersion      String
  status               AnalysisStatus @default(PENDING)
  detectedDocumentType String?
  extractedFields      Json?
  nameOnDocument       String?
  addressOnDocument    String?
  issuedDate           String?
  expiryDate           String?
  confidenceScore      Float?
  mismatchFlags        Json?
  analysisSummary      String?        @db.Text
  failureReason        String?
  analyzedAt           DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  document             Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_analyses")
}

model RefreshToken {
  id                String    @id @default(uuid())
  userId            String
  tokenHash         String
  status            String
  issuedAt          DateTime  @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  deviceLabel       String?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User           @relation(fields: [userId], references: [id])
  replacedBy        RefreshToken?  @relation("TokenReplacement", fields: [replacedByTokenId], references: [id])
  replacements      RefreshToken[] @relation("TokenReplacement")

  @@map("refresh_tokens")
}

model LifeEvent {
  id                    String                @id @default(uuid())
  name                  String
  normalizedKey         String                @unique
  description           String?
  category              String?
  expectedDocumentRules Json?
  isActive              Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  assessments           ReadinessAssessment[]

  @@map("life_events")
}

model ReadinessAssessment {
  id                String        @id @default(uuid())
  familyId          String
  familyMemberId    String?
  lifeEventId       String
  requestedByUserId String
  status            String
  readinessScore    Float?
  readinessLevel    String?
  availableDocuments Json?
  missingDocuments  Json?
  mismatchWarnings  Json?
  expiryWarnings    Json?
  nextSteps         String?
  processSummary    String?
  confidenceScore   Float?
  failureReason     String?
  assessedAt        DateTime      @default(now())
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  family            Family        @relation(fields: [familyId], references: [id])
  familyMember      FamilyMember? @relation(fields: [familyMemberId], references: [id])
  lifeEvent         LifeEvent     @relation(fields: [lifeEventId], references: [id])
  requestedByUser   User          @relation(fields: [requestedByUserId], references: [id])

  @@index([familyId])
  @@index([familyMemberId])
  @@index([lifeEventId])
  @@map("readiness_assessments")
}

model AIConversation {
  id            String      @id @default(uuid())
  familyId      String
  userId        String
  title         String?
  status        String      @default("active")
  lastMessageAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  family        Family      @relation(fields: [familyId], references: [id])
  user          User        @relation(fields: [userId], references: [id])
  messages      AIMessage[]

  @@index([familyId])
  @@index([userId])
  @@map("ai_conversations")
}

model AIMessage {
  id              String         @id @default(uuid())
  conversationId  String
  role            String
  content         String         @db.Text
  contextSummary  String?        @db.Text
  safetyStatus    String?
  confidenceScore Float?
  failureReason   String?
  createdAt       DateTime       @default(now())

  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}
